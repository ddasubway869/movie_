# ── Required ────────────────────────────────────────────────────────────────────

# TMDB API key — get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Secret used to sign session cookies — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Resend API key — get one at https://resend.com
RESEND_API_KEY=

# Public URL of the app — used in verification email links
APP_URL=https://slate.arvl.app

# ── Optional ────────────────────────────────────────────────────────────────────

# Port to listen on (default: 3000)
PORT=3000

# Absolute path to the SQLite database file (default: ~/.slate/slate.db)
# The default stores outside the app directory so data survives redeployments.
# Only set this if you need a custom location.
# DB_PATH=/home/user/.slate/slate.db

# Set to "production" when deploying — enables secure cookies over HTTPS
NODE_ENV=production
